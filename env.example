# ─── Solana network ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SOLANA_CLUSTER=mainnet-beta

# Optional: private RPC (recommended for mainnet — public RPC is rate-limited)
# NEXT_PUBLIC_SOLANA_RPC_URL=https://your-rpc-provider.com

# ─── Launch: official $CORN + treasury (set after pump.fun goes live) ─────────
# 1. npm run generate-treasury
# 2. npm run configure-token -- <OFFICIAL_PUMP_FUN_MINT_CA>
# 3. Fund treasury with SOL + $CORN, set TREASURY_SECRET_KEY, redeploy
# Remove any old test mint / treasury values from Vercel env vars before launch.
# NEXT_PUBLIC_TREASURY_PUBKEY=
# NEXT_PUBLIC_CORN_MINT=
NEXT_PUBLIC_CORN_DECIMALS=6
NEXT_PUBLIC_CORN_TOKEN_PROGRAM=token-2022

# Server signer for withdrawals — private key of NEXT_PUBLIC_TREASURY_PUBKEY
# JSON byte array from `npm run generate-treasury`, or base64 64-byte secret.
# Required for withdrawals (local .env.local + Vercel env vars). NEVER commit real keys.
# TREASURY_SECRET_KEY=

# ─── Persistent saves (survives Vercel redeploys) ─────────────────────────────
# Vercel Dashboard → corn-farm → Storage → connect corn-farm-blob to project
# Vercel auto-adds BLOB_STORE_ID (+ OIDC on each deploy). Legacy optional: BLOB_READ_WRITE_TOKEN
# BLOB_STORE_ID=
# BLOB_READ_WRITE_TOKEN=

# Local dev: vercel env pull .env.local
# Health check: GET /api/health/storage → { "backend": "blob" }
# Treasury readiness: GET /api/treasury/status (after mint is configured)
