# Solana RPC endpoint (defaults to devnet when unset)
NEXT_PUBLIC_SOLANA_RPC_URL=https://api.devnet.solana.com

# Treasury wallet that receives deposits and pays withdrawals
NEXT_PUBLIC_TREASURY_PUBKEY=

# Server-only treasury signer (JSON byte array or base64-encoded 64-byte secret)
TREASURY_SECRET_KEY=

# Generate a devnet treasury keypair:
# node scripts/generate-treasury.mjs
