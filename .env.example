# ─── Solana network ───────────────────────────────────────────────────────────
NEXT_PUBLIC_SOLANA_CLUSTER=mainnet-beta

# NEXT_PUBLIC_SOLANA_RPC_URL=https://your-rpc-provider.com

# ─── Treasury (fixed — same wallet as test phase) ────────────────────────────
NEXT_PUBLIC_TREASURY_PUBKEY=AXp2F7NP3cKU7nP8HXXL1XKuSrj1JeAYj2im4JKvNyvj

# Server-only — keep existing value from test in Vercel; do not change at launch.
# TREASURY_SECRET_KEY=

# ─── $CORN mint (set at launch — only this block changes) ─────────────────────
# npm run set-launch-mint -- <OFFICIAL_PUMP_FUN_MINT_CA>
# NEXT_PUBLIC_CORN_MINT=
# NEXT_PUBLIC_CORN_DECIMALS=6
# NEXT_PUBLIC_CORN_TOKEN_PROGRAM=token-2022

# ─── Launch checklist (when you have the official CA) ─────────────────────────
# 1. npm run set-launch-mint -- <CA>
# 2. Update Vercel env vars from script output (keep TREASURY_SECRET_KEY)
# 3. Redeploy
# 4. Fund treasury: SOL (fees) + official $CORN (withdrawals / prizes)
# 5. npm run verify-treasury
# 6. GET /api/treasury/status → readyForDeposits: true
