# Solana cluster: mainnet-beta (default), devnet, or testnet
NEXT_PUBLIC_SOLANA_CLUSTER=mainnet-beta

# Optional custom RPC (recommended for mainnet)
# NEXT_PUBLIC_SOLANA_RPC_URL=https://your-rpc-provider.com

# Treasury wallet public key (visible in UI)
NEXT_PUBLIC_TREASURY_PUBKEY=

# $CORN SPL mint address (visible on /tokenomics)
NEXT_PUBLIC_CORN_MINT=

# SPL token decimals (default 6)
# NEXT_PUBLIC_CORN_DECIMALS=6

# Treasury signer secret (server only — never expose to client)
# TREASURY_SECRET_KEY=
