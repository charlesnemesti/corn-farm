# ─── Solana network ───────────────────────────────────────────────────────────
# pump.fun tokens live on mainnet-beta
NEXT_PUBLIC_SOLANA_CLUSTER=mainnet-beta

# Strongly recommended — public RPC is rate-limited
# NEXT_PUBLIC_SOLANA_RPC_URL=https://your-rpc-provider.com

# ─── Official $CORN mint (set at launch) ─────────────────────────────────────
# Run after pump.fun goes live:
#   npm run configure-token -- <OFFICIAL_PUMP_FUN_MINT_CA>
# Remove any test mint from Vercel env vars before setting the real CA.
# NEXT_PUBLIC_CORN_MINT=

# Auto-filled by configure-token (default 6 for pump.fun)
# NEXT_PUBLIC_CORN_DECIMALS=6

# Auto-detected: spl | token-2022 | auto (default auto)
# NEXT_PUBLIC_CORN_TOKEN_PROGRAM=auto

# ─── Treasury wallet ──────────────────────────────────────────────────────────
# Generate a fresh treasury keypair:
#   npm run generate-treasury
# NEXT_PUBLIC_TREASURY_PUBKEY=

# Server-only signer for withdrawals — NEVER expose to the client
# TREASURY_SECRET_KEY=

# ─── Launch checklist ─────────────────────────────────────────────────────────
# 1. npm run generate-treasury
# 2. npm run configure-token -- <OFFICIAL_PUMP_FUN_MINT_CA>
# 3. Fund treasury wallet with SOL (fees) + $CORN (withdrawals / prizes)
# 4. Set env vars in Vercel → Redeploy (~5–10 min until live in-game)
# 5. npm run verify-treasury
# 6. GET /api/treasury/status — confirm readyForDeposits
